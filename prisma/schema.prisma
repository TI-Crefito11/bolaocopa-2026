generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
}

enum MatchStatus {
  SCHEDULED
  CLOSED
  FINISHED
}

enum PoolTransactionKind {
  ADD
  REMOVE
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  poolTransactions PoolTransaction[]
}

model Participant {
  id            Int           @id @default(autoincrement())
  name          String
  email         String
  phone         String
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bets          Bet[]

  @@unique([email, phone])
}

model Match {
  id             Int         @id @default(autoincrement())
  opponent       String
  kickoffAt      DateTime
  betDeadlineAt  DateTime
  status         MatchStatus @default(SCHEDULED)
  brazilGoals    Int?
  opponentGoals  Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  bets           Bet[]
  scorers        MatchScorer[]

  @@index([kickoffAt])
}

model Bet {
  id            Int         @id @default(autoincrement())
  participantId Int
  matchId       Int
  brazilGoals   Int
  opponentGoals Int
  submittedAt   DateTime    @default(now())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorers       BetScorer[]

  @@unique([participantId, matchId])
  @@index([matchId])
}

model Player {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  betScorers   BetScorer[]
  matchScorers MatchScorer[]
}

model BetScorer {
  id       Int    @id @default(autoincrement())
  betId    Int
  playerId Int
  position Int
  bet      Bet    @relation(fields: [betId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([betId, position])
  @@index([playerId])
}

model MatchScorer {
  id       Int    @id @default(autoincrement())
  matchId  Int
  playerId Int
  position Int
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([matchId, position])
  @@index([playerId])
}

model PoolTransaction {
  id          Int                 @id @default(autoincrement())
  kind        PoolTransactionKind
  amountCents Int
  description String
  createdAt   DateTime            @default(now())
  createdById Int
  createdBy   AdminUser           @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([createdById])
}
